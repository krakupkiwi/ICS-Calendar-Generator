# Copy this file to .env and adjust values before running docker compose

# Port to expose the app on the host
# Change this if the default port is already in use on your server
HOST_PORT=8432

# Timezone for ICS event times (IANA timezone name)
# Google/Apple/Outlook Calendar will display times in this timezone.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Australia/Perth
